<?xml version="1.0" encoding="UTF-8"?>

<odoo>

    <template id="property_agent" name="Property Agent Snippet">

        <section>
            <div class="container">
                <div class="row g-2">
                    
                    <!-- প্রথম কলাম (col-lg-6) -->
                    <div class="col-lg-6 carosel-image">
                        <div id="carouselExampleControlsNoTouching" class="carousel slide" data-bs-touch="false" data-bs-ride="carousel" data-bs-interval="2000">
                        <div class="carousel-inner">
                            <div class="carousel-item active">
                            <img src="https://arabianstorebd.com/wp-content/uploads/2025/06/1-1.webp" class="d-block w-100" alt="..."/>
                            </div>
                            <div class="carousel-item">
                            <img src="https://arabianstorebd.com/wp-content/uploads/2025/06/2.webp" class="d-block w-100" alt="..."/>
                            </div>
                            <div class="carousel-item">
                            <img src="https://arabianstorebd.com/wp-content/uploads/2025/06/3.webp" class="d-block w-100" alt="..."/>
                            </div>
                        </div>
                        <button class="carousel-control-prev" type="button" data-bs-target="#carouselExampleControlsNoTouching" data-bs-slide="prev">
                            <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                            <span class="visually-hidden">Previous</span>
                        </button>
                        <button class="carousel-control-next" type="button" data-bs-target="#carouselExampleControlsNoTouching" data-bs-slide="next">
                            <span class="carousel-control-next-icon" aria-hidden="true"></span>
                            <span class="visually-hidden">Next</span>
                        </button>
                        </div>
                    </div>

                    <!-- দ্বিতীয় কলাম (col-lg-6) -->
                    <div class="col-lg-6">
                        <div>
                            
                            <div class="banner-item1 banner-item">
                                <img src="https://arabianstorebd.com/wp-content/uploads/2025/07/Arabian_Website_Mejool2.webp" class="img-fluid"/>
                            </div>
                            <div class="d-flex mt-2">
                                <div class="col-lg-6 banner-item2 banner-item me-1">
                                    <img src="https://arabianstorebd.com/wp-content/uploads/2025/06/984.webp" class="img-fluid"/>
                                </div>
                                <div class="col-lg-6 banner-item2 banner-item ms-1">
                                    <img src="https://arabianstorebd.com/wp-content/uploads/2025/06/984-2.webp" class="img-fluid"/>
                                </div>
                            </div>

                        </div>
                    </div>

                </div>
            </div>
        </section>

    </template>

</odoo>